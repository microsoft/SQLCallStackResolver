<UserControl x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern">
    <UserControl.Resources>
        <local:StepToBoldConverter x:Key="StepToBold"/>
        <local:StepToBrushConverter x:Key="StepToBrush"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar: Step indicators -->
        <Border Grid.Column="0" Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}" Padding="12,16" CornerRadius="4,0,0,4">
            <StackPanel>
                <TextBlock Text="Steps" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Cursor="Hand"
                            MouseLeftButtonDown="StepLabel_Click" Tag="0">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=0}"/>
                    <TextBlock Text="1. Provide Input"
                               FontWeight="{Binding CurrentStep, Converter={StaticResource StepToBold}, ConverterParameter=0}"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=0}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Cursor="Hand"
                            MouseLeftButtonDown="StepLabel_Click" Tag="1">
                    <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=1}"/>
                    <TextBlock Text="2. Configure Symbols"
                               FontWeight="{Binding CurrentStep, Converter={StaticResource StepToBold}, ConverterParameter=1}"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=1}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Cursor="Hand"
                            MouseLeftButtonDown="StepLabel_Click" Tag="2">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=2}"/>
                    <TextBlock Text="3. Output Options"
                               FontWeight="{Binding CurrentStep, Converter={StaticResource StepToBold}, ConverterParameter=2}"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=2}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" Cursor="Hand"
                            MouseLeftButtonDown="StepLabel_Click" Tag="3">
                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=3}"/>
                    <TextBlock Text="4. Resolve"
                               FontWeight="{Binding CurrentStep, Converter={StaticResource StepToBold}, ConverterParameter=3}"
                               Foreground="{Binding CurrentStep, Converter={StaticResource StepToBrush}, ConverterParameter=3}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Right content: Current page + navigation -->
        <DockPanel Grid.Column="1" Margin="12,0,0,0">
            <!-- Bottom navigation -->
            <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Width="90" Padding="4,6"
                        Command="{Binding PreviousStepCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Width="90" Padding="4,6" Margin="0,0,8,0"
                        Command="{Binding NextStepCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Next"/>
                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Width="100" Padding="4,6" FontWeight="Bold"
                        Command="{Binding ResolveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Resolve!" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Page content area -->
            <ContentControl x:Name="PageContent"/>
        </DockPanel>
    </Grid>
</UserControl>
