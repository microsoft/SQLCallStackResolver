<UserControl x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern">
    <UserControl.Resources>
        <local:StepToBoldConverter x:Key="StepToBold"/>
        <local:StepToBrushConverter x:Key="StepToBrush"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <local:BoolToMarginConverter x:Key="BoolToMargin"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar: Dynamic step indicators -->
        <Border Grid.Column="0" Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}" Padding="12,16" CornerRadius="4,0,0,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Steps" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                <ItemsControl x:Name="StepsList" DockPanel.Dock="Top">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="{Binding IsConditional, Converter={StaticResource BoolToMargin}}" Cursor="Hand"
                                        MouseLeftButtonDown="StepItem_Click">
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Label}" FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Right content: Current page + navigation -->
        <DockPanel Grid.Column="1" Margin="12,0,0,0">
            <!-- Bottom navigation -->
            <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Width="90" Padding="4,6" Margin="0,0,8,0"
                        Command="{Binding PreviousStepCommand}"
                        Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Width="120" Padding="4,6"
                        Command="{Binding StartOverCommand}"
                        Visibility="{Binding CanStartOver, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Start Over"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Width="90" Padding="4,6" Margin="0,0,8,0"
                        Command="{Binding NextStepCommand}"
                        Visibility="{Binding ShowNextButton, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Next"/>
                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="4" Width="120" Padding="4,6" FontWeight="Bold"
                        Command="{Binding ResolveCommand}"
                        Visibility="{Binding IsOnStepBeforeResolve, Converter={StaticResource BoolToVis}}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HighlightResolve}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="GlowStoryboard">
                                            <Storyboard RepeatBehavior="3x">
                                                <ColorAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Color)"
                                                                To="#40C040" Duration="0:0:0.4" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                                 To="1" Duration="0:0:0.4" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="GlowStoryboard"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Effect>
                        <DropShadowEffect Color="Transparent" ShadowDepth="0" BlurRadius="15" Opacity="0"/>
                    </Button.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Resolve!" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Page content area -->
            <ContentControl x:Name="PageContent"/>
        </DockPanel>
    </Grid>
</UserControl>
