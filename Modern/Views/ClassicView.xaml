<UserControl x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.ClassicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern"
             FontSize="12">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Gesture="Ctrl+F" Command="Find"/>
    </UserControl.InputBindings>
    <UserControl.CommandBindings>
        <CommandBinding Command="Find" Executed="Find_Executed"/>
    </UserControl.CommandBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Input / Output split -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="100"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="100"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Input" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox x:Name="inputTextBox" AcceptsReturn="True" AcceptsTab="True"
                         IsInactiveSelectionHighlightEnabled="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="13" TextWrapping="NoWrap"
                         MaxLength="999999999"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AllowDrop="True" PreviewDragOver="CallStackInput_DragOver" Drop="CallStackInput_Drop"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Output" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <local:FindBar x:Name="findBar" DockPanel.Dock="Top"/>
                <TextBox x:Name="outputTextBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         IsInactiveSelectionHighlightEnabled="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="13" TextWrapping="NoWrap"
                         Text="{Binding OutputText, Mode=OneWay}"/>
            </DockPanel>
        </Grid>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="LightGray"/>

        <!-- Detection banners -->
        <StackPanel Grid.Row="2" Margin="0,4,0,0">
            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundAccentBrush}"
                    BorderThickness="1"
                    Visibility="{Binding HasDetectedBuild, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                        <Run Text="Detected SQL Server" FontWeight="SemiBold"/>
                        <Run Text="{Binding DetectedBuildVersion, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" — use the 'For a SQL version' button to download symbols."/>
                    </TextBlock>
                </DockPanel>
            </Border>
            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundAccentBrush}"
                    BorderThickness="1"
                    Visibility="{Binding HasXmlFrameInput, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                               Text="XML frames with PDB info detected — use the 'MS Symbol Server' button to set the symbol path."/>
                </DockPanel>
            </Border>
            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    BorderBrush="Orange" BorderThickness="1"
                    Visibility="{Binding NeedsBaseAddresses, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="Orange"/>
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                               Text="Virtual addresses detected — click 'Enter base addresses' to provide module base address info."/>
                </DockPanel>
            </Border>
        </StackPanel>

        <!-- Bottom: Configuration panels in 2x2 grid -->
        <Grid Grid.Row="3" Margin="0,4,0,0" TextElement.FontSize="11">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="55*"/>
                <ColumnDefinition Width="45*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top-left: Input / Output Options -->
            <GroupBox Grid.Row="1" Grid.Column="0" Header="Input / Output Options" Margin="0,0,4,4" Padding="6,2,6,6" FontSize="10">
                <Grid Margin="0,-2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Input column -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Input" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <Button Click="LoadXEL_Click" Padding="10,6" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsNotProcessing}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Import XEL..."/>
                                </StackPanel>
                            </Button>
                            <CheckBox Content="Group XEL events" VerticalAlignment="Center"
                                      IsChecked="{Binding GroupXEvents}"/>
                        </StackPanel>
                        <Button Margin="0,0,0,3" Click="EnterBaseAddresses_Click"
                                HorizontalAlignment="Left" Padding="10,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NeedsBaseAddresses}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="BaseAddrGlow">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <ColorAnimation Storyboard.TargetProperty="(Button.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="Orange" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="BaseAddrGlow"/>
                                            </DataTrigger.ExitActions>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="Transparent"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Enter base addresses..."/>
                            </StackPanel>
                        </Button>
                        <Expander Header="Advanced input options" IsExpanded="False" Margin="0,0,0,0">
                            <StackPanel Margin="16,4,0,0">
                                <CheckBox Content="Frames on single line" Margin="0,0,0,3"
                                          IsChecked="{Binding FramesOnSingleLine}"/>
                                <CheckBox Content="Re-lookup source" Margin="0,0,0,3"
                                          IsChecked="{Binding RelookupSource}"/>
                                <TextBlock Text="Binary paths (OrdinalNNN):" Foreground="Gray" Margin="0,2,0,2"/>
                                <DockPanel Margin="0,0,0,3">
                                    <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowseBinaryPath_Click"
                                            ToolTip="Browse for binary folder"/>
                                    <TextBox Text="{Binding BinaryPaths, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,2,0"
                                             ToolTip="Binary paths for ordinal resolution (semicolon-separated)"/>
                                </DockPanel>
                                <CheckBox Content="Search DLLs recursively" IsChecked="{Binding DllRecurse}"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <!-- Output column -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Output" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <TextBlock Text="Save output to file:" Foreground="Gray" Margin="0,0,0,2"/>
                        <DockPanel Margin="0,0,0,3">
                            <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowseOutputPath_Click"
                                    ToolTip="Browse for output file location"/>
                            <TextBox Text="{Binding OutputFilePath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Output file path (optional)" Margin="0,0,2,0"/>
                        </DockPanel>
                        <Expander Header="Advanced output options" IsExpanded="False" Margin="0,0,0,0">
                            <StackPanel Margin="16,4,0,0">
                                <CheckBox Content="Source lines (private PDBs)" Margin="0,0,0,3"
                                          IsChecked="{Binding IncludeLineNumbers}"/>
                                <CheckBox Content="Function offsets" Margin="0,0,0,3"
                                          IsChecked="{Binding IncludeOffsets}"/>
                                <CheckBox Content="Inline frames" Margin="0,0,0,0"
                                          IsChecked="{Binding ShowInlineFrames}"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Top-right: Symbol / PDB Paths -->
            <GroupBox Grid.Row="1" Grid.Column="1" Header="Symbol / PDB Paths" Margin="4,0,0,4" Padding="6" FontSize="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Click="SelectSQLPDB_Click" Padding="10,6" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDetectedBuild}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="SqlBuildGlow">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <ColorAnimation Storyboard.TargetProperty="(Button.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="#40C040" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="SqlBuildGlow"/>
                                            </DataTrigger.ExitActions>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="Transparent"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="For a SQL version..."/>
                            </StackPanel>
                        </Button>
                        <Button Click="UseSymbolServer_Click" Padding="10,6"
                                ToolTip="SRV*c:\temp\symcache*https://msdl.microsoft.com/download/symbols">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasXmlFrameInput}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="SymSrvGlow">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <ColorAnimation Storyboard.TargetProperty="(Button.BorderBrush).(SolidColorBrush.Color)"
                                                                        To="#40C040" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="SymSrvGlow"/>
                                            </DataTrigger.ExitActions>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="Transparent"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="MS Symbol Server"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="PDB search paths:" Foreground="Gray" Margin="0,0,0,2"/>
                    <DockPanel Margin="0,0,0,4">
                        <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding PinPdbPaths}"
                                      Padding="4,2" Background="Transparent" BorderThickness="0" Margin="2,0,0,0"
                                      ToolTip="Pin to remember this path for next session">
                            <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Opacity="{Binding PinPdbPaths, Converter={StaticResource BoolToOpacityConverter}}"/>
                        </ToggleButton>
                        <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowsePdbPath_Click"
                                ToolTip="Browse for PDB folder"/>
                        <TextBox Text="{Binding PdbPaths, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,2,0"
                                 ToolTip="PDB paths (semicolon-separated)"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Search recursively" Margin="0,0,16,0" IsChecked="{Binding PdbRecurse}"/>
                        <CheckBox Content="Cache PDBs locally" IsChecked="{Binding CachePDB}"
                                  ToolTip="Copies PDBs to %TEMP%\SymCache"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Bottom row: Split resolve button -->
            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="resolveMainButton" FontWeight="Bold" Padding="14,6"
                            Width="230" Click="ResolveMain_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HighlightResolve}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="GlowStoryboard">
                                                <Storyboard RepeatBehavior="3x">
                                                    <ColorAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Color)"
                                                                    To="#40C040" Duration="0:0:0.4" AutoReverse="True"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                                     To="1" Duration="0:0:0.4" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="GlowStoryboard"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Effect>
                            <DropShadowEffect Color="Transparent" ShadowDepth="0" BlurRadius="15" Opacity="0"/>
                        </Button.Effect>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="resolveMainIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="resolveMainText" Text="Resolve Callstacks!" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="6,6" Margin="1,0,0,0" Click="ResolveDropdown_Click"
                            VerticalAlignment="Stretch"
                            ToolTip="Choose resolve action">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="resolveMenu" Placement="Left">
                                <MenuItem Header="Resolve Callstacks" Click="ResolveMenuItem_Click" Tag="resolve">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Paste clipboard &amp; resolve" Click="ResolveMenuItem_Click" Tag="paste">
                                    <MenuItem.Icon>
                                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
