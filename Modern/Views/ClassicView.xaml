<UserControl x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.ClassicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern"
             FontSize="12">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Gesture="Ctrl+F" Command="Find"/>
    </UserControl.InputBindings>
    <UserControl.CommandBindings>
        <CommandBinding Command="Find" Executed="Find_Executed"/>
    </UserControl.CommandBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: Input / Output split -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="100"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="100"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Input" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox AcceptsReturn="True" AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="13" TextWrapping="NoWrap"
                         MaxLength="999999999"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AllowDrop="True" PreviewDragOver="CallStackInput_DragOver" Drop="CallStackInput_Drop"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Output" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <local:FindBar x:Name="findBar" DockPanel.Dock="Top"/>
                <TextBox x:Name="outputTextBox" IsReadOnly="True" AcceptsReturn="True"
                         IsInactiveSelectionHighlightEnabled="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="13" TextWrapping="NoWrap"
                         Text="{Binding OutputText, Mode=OneWay}"/>
            </DockPanel>
        </Grid>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="LightGray"/>

        <!-- Bottom: Configuration panels in 2x2 grid -->
        <Grid Grid.Row="2" Margin="0,4,0,0" TextElement.FontSize="11">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Detection banners (version or XML frame) -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundAccentBrush}"
                    BorderThickness="1"
                    Visibility="{Binding HasDetectedBuild, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Padding="8,4" Click="DownloadDetectedBuild_Click"
                            Style="{DynamicResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Download Symbols"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                        <Run Text="Detected SQL Server" FontWeight="SemiBold"/>
                        <Run Text="{Binding DetectedBuildVersion, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" - "/>
                        <Run Text="{Binding DetectedBuildDetails, Mode=OneWay}" Foreground="Gray"/>
                    </TextBlock>
                </DockPanel>
            </Border>
            <Border Grid.Row="0" Grid.ColumnSpan="2" CornerRadius="4" Padding="8,6" Margin="0,0,0,6"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundAccentBrush}"
                    BorderThickness="1"
                    Visibility="{Binding HasXmlFrameInput, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Padding="8,4" Click="UseSymbolServer_Click"
                            Style="{DynamicResource AccentButtonStyle}"
                            ToolTip="SRV*c:\temp\symcache*https://msdl.microsoft.com/download/symbols">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Use Symbol Server"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                        <Run Text="XML frames with PDB info detected" FontWeight="SemiBold"/>
                        <Run Text=" - Modules: "/>
                        <Run Text="{Binding DetectedPdbModules, Mode=OneWay}" Foreground="Gray"/>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- Top-left: Input/Output Options + Import -->
            <GroupBox Grid.Row="1" Grid.Column="0" Header="Input / Output Options" Margin="0,0,4,4" Padding="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <CheckBox Content="Frames on single line" Margin="0,0,0,3"
                                  IsChecked="{Binding FramesOnSingleLine}"/>
                        <CheckBox Content="Re-lookup source" Margin="0,0,0,3"
                                  IsChecked="{Binding RelookupSource}"/>
                        <CheckBox Content="Source lines (private PDBs)" Margin="0,0,0,3"
                                  IsChecked="{Binding IncludeLineNumbers}"/>
                        <CheckBox Content="Function offsets" Margin="0,0,0,3"
                                  IsChecked="{Binding IncludeOffsets}"/>
                        <CheckBox Content="Inline frames" Margin="0,0,0,3"
                                  IsChecked="{Binding ShowInlineFrames}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Click="LoadXEL_Click" Padding="8,3" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsNotProcessing}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Import XEL..."/>
                                </StackPanel>
                            </Button>
                            <CheckBox Content="Group XEL events" VerticalAlignment="Center"
                                      IsChecked="{Binding GroupXEvents}"/>
                        </StackPanel>
                        <Button Margin="0,0,0,6" Click="EnterBaseAddresses_Click"
                                HorizontalAlignment="Left" Padding="8,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Enter base addresses..."/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="Save output to file:" Foreground="Gray" Margin="0,0,0,2"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowseOutputPath_Click"
                                    ToolTip="Browse for output file location"/>
                            <TextBox Text="{Binding OutputFilePath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Output file path (optional)" Margin="0,0,2,0"/>
                        </DockPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Top-right: Symbol / PDB paths -->
            <GroupBox Grid.Row="1" Grid.Column="1" Header="Symbol / PDB Paths" Margin="4,0,0,4" Padding="4">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Click="SelectSQLPDB_Click" Padding="8,3" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="For a SQL version..."/>
                            </StackPanel>
                        </Button>
                        <Button Click="UseSymbolServer_Click" Padding="8,3"
                                ToolTip="SRV*c:\temp\symcache*https://msdl.microsoft.com/download/symbols">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="MS Symbol Server"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="PDB search paths:" Foreground="Gray" Margin="0,0,0,2"/>
                    <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowsePdbPath_Click"
                                ToolTip="Browse for PDB folder"/>
                        <TextBox Text="{Binding PdbPaths, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,2,0"
                                 ToolTip="PDB paths (semicolon-separated)"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox Content="Search recursively" Margin="0,0,16,0" IsChecked="{Binding PdbRecurse}"/>
                        <CheckBox Content="Cache PDBs locally" IsChecked="{Binding CachePDB}"
                                  ToolTip="Copies PDBs to %TEMP%\SymCache"/>
                    </StackPanel>
                    <TextBlock Text="Binary paths (for OrdinalNNN resolution):" Foreground="Gray" Margin="0,0,0,2"/>
                    <DockPanel Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowseBinaryPath_Click"
                                ToolTip="Browse for binary folder"/>
                        <TextBox Text="{Binding BinaryPaths, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,2,0"
                                 ToolTip="Binary paths for ordinal resolution (semicolon-separated)"/>
                    </DockPanel>
                    <CheckBox Content="Search DLLs recursively" IsChecked="{Binding DllRecurse}"/>
                </StackPanel>
            </GroupBox>

            <!-- Bottom row: Resolve spanning full width -->
            <Grid Grid.Row="2" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="2" Padding="10,6" Margin="0,0,8,0"
                        Command="{Binding PasteFromClipboardCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Paste clipboard &amp; resolve"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" FontWeight="Bold" Padding="14,6"
                        Command="{Binding ResolveCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Resolve Callstacks!" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
