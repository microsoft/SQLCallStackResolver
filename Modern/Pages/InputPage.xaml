<UserControl x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.InputPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                   Text="Step 1: Provide Callstack Input"/>
        <TextBlock Grid.Row="0" FontSize="11" Foreground="Gray" Margin="0,24,0,4"
                   Text="Paste raw callstack(s) below, or import from XEL files, or drag and drop text/XEL files."/>

        <TextBox Grid.Row="1" x:Name="callStackInput" AcceptsReturn="True" AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                 MaxLength="999999999"
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 AllowDrop="True" PreviewDragOver="CallStackInput_DragOver" Drop="CallStackInput_Drop"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Import XEL file(s)..." Width="130" Margin="0,0,8,0" Click="LoadXEL_Click"
                    IsEnabled="{Binding IsNotProcessing}"/>
            <Button Content="Paste from clipboard" Width="140" Margin="0,0,8,0"
                    Command="{Binding PasteFromClipboardCommand}"/>
        </StackPanel>

        <GroupBox Grid.Row="3" Header="Input Options" Margin="0,8,0,0" Padding="6">
            <WrapPanel>
                <CheckBox Content="Callstack frames are on a single line" Margin="0,0,16,4"
                          IsChecked="{Binding FramesOnSingleLine}"/>
                <CheckBox Content="Re-lookup source (rare, needs private PDBs)" Margin="0,0,16,4"
                          IsChecked="{Binding RelookupSource}"/>
                <CheckBox Content="Group events from XEL files" Margin="0,0,16,4"
                          IsChecked="{Binding GroupXEvents}"/>
                <Button Content="Enter base addresses..." Margin="0,0,16,4" Padding="8,2" Click="EnterBaseAddresses_Click"/>
            </WrapPanel>
        </GroupBox>
    </Grid>
</UserControl>
