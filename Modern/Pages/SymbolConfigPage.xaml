<UserControl x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.SymbolConfigPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"
                       Text="Configure Symbol Paths"/>
            <TextBlock FontSize="12" Foreground="Gray"
                       Text="Use preset symbol downloads for a known SQL Server build, or set custom PDB search paths."/>
        </StackPanel>

        <!-- Auto-detected version suggestion -->
        <Border Grid.Row="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundAccentBrush}"
                BorderThickness="1"
                Visibility="{Binding HasDetectedBuild, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Detected SQL Server " FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="{Binding DetectedBuildVersion}" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DetectedBuildDetails}" FontSize="12" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button Grid.Column="2" Padding="12,6" Click="DownloadDetectedBuild_Click"
                        Style="{DynamicResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Download Symbols"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- XML frame input with PDB GUIDs detected — suggest symbol server -->
        <Border Grid.Row="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,10"
                Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundAccentBrush}"
                BorderThickness="1"
                Visibility="{Binding HasXmlFrameInput, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource SystemControlForegroundAccentBrush}"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="XML frames with PDB info detected" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock FontSize="12" Foreground="Gray" TextTrimming="CharacterEllipsis">
                        <Run Text="Modules:"/>
                        <Run Text="{Binding DetectedPdbModules, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="2" Padding="12,6" Click="UseSymbolServer_Click"
                        Style="{DynamicResource AccentButtonStyle}"
                        ToolTip="SRV*c:\temp\symcache*https://msdl.microsoft.com/download/symbols">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Use Symbol Server"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Quick actions: preset symbol sources -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Padding="10,6" Margin="0,0,8,0" Click="SelectSQLPDB_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="For a SQL Server version..."/>
                </StackPanel>
            </Button>
            <Button Padding="10,6" Click="UseSymbolServer_Click" ToolTip="SRV*c:\temp\symcache*https://msdl.microsoft.com/download/symbols">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Microsoft Symbol Server"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- PDB Paths (manual) -->
        <GroupBox Grid.Row="3" Header="PDB Symbol Paths" Padding="6" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock FontSize="11.5" Foreground="Gray" Margin="0,0,0,4"
                           Text="Local folder(s), UNC path(s), or WinDbg-style symbol server(s). If using multiple paths; separate using semicolons."/>
                <DockPanel>
                <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding PinPdbPaths}"
                              Padding="4,2" Background="Transparent" BorderThickness="0" Margin="2,0,0,0"
                              ToolTip="Pin to remember this path for next session">
                    <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Opacity="{Binding PinPdbPaths, Converter={StaticResource BoolToOpacityConverter}}"/>
                </ToggleButton>
                <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowsePdbPath_Click"
                        ToolTip="Browse for PDB folder"/>
                <TextBox Text="{Binding PdbPaths, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,2,0" ToolTip="Semicolon-separated paths to PDB files"/>
            </DockPanel>
            </StackPanel>
        </GroupBox>

        <!-- Output options (collapsed by default) -->
        <Expander Grid.Row="4" Margin="0,4,0,0" IsExpanded="False">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,6,0" Foreground="Gray"/>
                    <TextBlock Text="Output options" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Expander.Header>
            <StackPanel Margin="24,8,0,0">
                <CheckBox Content="Include source file and line numbers (requires private PDBs)" Margin="0,0,0,6"
                          IsChecked="{Binding IncludeLineNumbers}"/>
                <CheckBox Content="Include function offsets" Margin="0,0,0,6"
                          IsChecked="{Binding IncludeOffsets}"/>
                <CheckBox Content="Show inline frames" Margin="0,0,0,6"
                          IsChecked="{Binding ShowInlineFrames}"/>
                <GroupBox Header="Output Destination" Padding="6" Margin="0,4,0,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowseOutputPath_Click"
                                ToolTip="Browse for output file location"/>
                        <TextBlock DockPanel.Dock="Left" Text="Save to file:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding OutputFilePath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,2,0" ToolTip="Leave empty to display output in the results area"/>
                    </DockPanel>
                </GroupBox>
                <TextBlock FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="Tip: For very large inputs, saving output to a file is recommended to avoid truncation."/>
            </StackPanel>
        </Expander>

        <!-- Advanced symbol options (collapsed by default) -->
        <Expander Grid.Row="5" Margin="0,4,0,0" IsExpanded="False">
            <Expander.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,6,0" Foreground="Gray"/>
                    <TextBlock Text="Advanced symbol options" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </Expander.Header>
            <StackPanel Margin="24,8,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox Content="Search PDBs recursively" Margin="0,0,16,0" IsChecked="{Binding PdbRecurse}"/>
                    <CheckBox Content="Cache PDBs locally" Margin="0,0,0,0" IsChecked="{Binding CachePDB}"
                              ToolTip="Copies PDBs to %TEMP%\SymCache"/>
                </StackPanel>

                <GroupBox Header="Binary Paths (only needed when frames have OrdinalNNN values)" Padding="6" Margin="0,0,0,8">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <Button DockPanel.Dock="Right" Content="..." Width="30" Click="BrowseBinaryPath_Click"
                                    ToolTip="Browse for binary folder"/>
                            <TextBox Text="{Binding BinaryPaths, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,2,0" ToolTip="Semicolon-separated paths to SQL Server binaries (DLL/EXE)"/>
                        </DockPanel>
                        <CheckBox Content="Search for DLLs and EXEs recursively"
                                  IsChecked="{Binding DllRecurse}"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap"
                           Text="Tip: If using UNC paths for PDBs, enabling 'Cache PDBs locally' can significantly speed up resolution over WAN connections."/>
            </StackPanel>
        </Expander>
    </Grid>
</UserControl>
