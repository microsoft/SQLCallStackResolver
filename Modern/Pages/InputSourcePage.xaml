<UserControl x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.InputSourcePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AllowDrop="True" PreviewDragOver="InputSource_DragOver" Drop="InputSource_Drop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"
                       Text="How would you like to provide input?"/>
            <TextBlock FontSize="12" Foreground="Gray"
                       Text="Choose an input method to get started."/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,0" MaxHeight="220">
            <!-- Direct Input card -->
            <Border x:Name="DirectInputCard" Margin="0,0,12,0" Padding="24" CornerRadius="8"
                    BorderThickness="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
                    Cursor="Hand" MouseLeftButtonDown="DirectInputCard_Click"
                    MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                               HorizontalAlignment="Center" Margin="0,0,0,12" Foreground="DodgerBlue"/>
                    <TextBlock Text="Enter / Paste Callstacks" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Type or paste raw callstack text directly, or drag and drop text files."
                               FontSize="12" Foreground="Gray" TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="220"/>
                </StackPanel>
            </Border>

            <!-- XEL Import card -->
            <Border x:Name="XELImportCard" Margin="12,0,0,0" Padding="24" CornerRadius="8"
                    BorderThickness="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
                    Cursor="Hand" MouseLeftButtonDown="XELImportCard_Click"
                    MouseEnter="Card_MouseEnter" MouseLeave="Card_MouseLeave">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                               HorizontalAlignment="Center" Margin="0,0,0,12" Foreground="DodgerBlue"/>
                    <TextBlock Text="Import from XEL Files" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Load callstacks from Extended Event (XEL) trace files."
                               FontSize="12" Foreground="Gray" TextWrapping="Wrap" TextAlignment="Center"
                               MaxWidth="220"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <TextBlock Grid.Row="2" FontSize="12" Foreground="Gray" HorizontalAlignment="Center" Margin="0,16,0,0"
                   Text="Tip: You can also drag and drop .xel or text files here."/>
    </Grid>
</UserControl>
