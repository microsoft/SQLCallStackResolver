<Window x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="app.ico"
        Title="SQLCallStackResolver (https://aka.ms/sqlstack)" Height="700" Width="1050" MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding ResolveCommand}"/>
        <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+V" Command="{Binding PasteFromClipboardCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>
    <Grid>
        <DockPanel x:Name="MainContent">

        <!-- Bottom status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0">
                <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="8,0,4,0" FontSize="11" Opacity="0.7"/>
                    <RadioButton x:Name="WizardRadio" Content="Simple" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"
                                 GroupName="ViewMode" Checked="WizardRadio_Checked"/>
                    <RadioButton x:Name="ClassicRadio" Content="Classic" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                                 GroupName="ViewMode" Checked="ClassicRadio_Checked"/>
                    <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="2,2,6,2"/>
                    <ToggleButton x:Name="ThemeToggle" Click="ThemeToggle_Click" Padding="4,2"
                                  ToolTip="Toggle dark/light theme" Background="Transparent" BorderThickness="0">
                        <TextBlock x:Name="ThemeIcon" Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </ToggleButton>
                    <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="6,2,6,2"/>
                    <Button Click="HelpAbout_Click" Padding="4,2" ToolTip="About SQLCallStackResolver"
                            Background="Transparent" BorderThickness="0">
                        <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content: switches between Wizard and Classic -->
        <Grid Margin="8">
            <local:WizardView x:Name="wizardView" Visibility="{Binding IsWizardMode, Converter={StaticResource BoolToVis}}"/>
            <local:ClassicView x:Name="classicView" Visibility="{Binding IsWizardMode, Converter={StaticResource InvBoolToVis}}"/>
        </Grid>
        </DockPanel>

        <!-- Processing overlay with spinner -->
        <Border Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                Background="#80000000" Panel.ZIndex="50">
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                    CornerRadius="12" Padding="40,32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="320"
                    BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <!-- Spinning ring -->
                    <ui:ProgressRing IsActive="{Binding IsProcessing}" Width="48" Height="48" Margin="0,0,0,16"/>
                    <!-- Status text -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" TextAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="280" Margin="0,0,0,16"/>
                    <!-- Cancel button -->
                    <Button Command="{Binding CancelCommand}" HorizontalAlignment="Center"
                            Padding="24,8" ToolTip="Cancel (Esc)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Cancel"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Border>

        <!-- Splash overlay -->
        <Border x:Name="SplashOverlay" Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
                Visibility="Visible" Panel.ZIndex="100">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        CornerRadius="8" Padding="40,36" BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.3"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- App icon and title -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Image x:Name="SplashIcon" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,14,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="SQLCallStackResolver" FontSize="22" FontWeight="Bold"/>
                                <TextBlock x:Name="SplashVersion" Text="" FontSize="12" Foreground="Gray"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Legal notice -->
                        <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                   Margin="0,0,0,10" LineHeight="18"
                                   Text="Copyright &#169; 2025 Microsoft Corporation. All rights reserved."/>
                        <TextBlock TextWrapping="Wrap" FontSize="10.5" Opacity="0.8" Margin="0,0,0,10" LineHeight="16"
                                   Text="THIS SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE."/>
                        <TextBlock TextWrapping="Wrap" FontSize="10.5" Opacity="0.8" Margin="0,0,0,24" LineHeight="16"
                                   Text="Usage of the Microsoft Symbol Server is covered by the license terms published at https://docs.microsoft.com/legal/windows-sdk/microsoft-symbol-server-license-terms."/>

                        <!-- Accept button -->
                        <Button x:Name="SplashAcceptButton" Content="I Accept" HorizontalAlignment="Center"
                                Padding="32,8" FontWeight="SemiBold" Click="SplashAccept_Click"
                                Style="{DynamicResource AccentButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
