<Window x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="SQL Call Stack Resolver" Height="700" Width="1050" MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>
    <DockPanel>
        <!-- Top toolbar: Mode toggle -->
        <Border DockPanel.Dock="Top" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="SQL Call Stack Resolver" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton x:Name="WizardRadio" Content="Wizard" VerticalAlignment="Center" Margin="0,0,12,0"
                                 GroupName="ViewMode" Checked="WizardRadio_Checked"/>
                    <RadioButton x:Name="ClassicRadio" Content="Classic" VerticalAlignment="Center"
                                 GroupName="ViewMode" Checked="ClassicRadio_Checked"/>
                </StackPanel>
                <ToggleButton Grid.Column="3" x:Name="ThemeToggle" Click="ThemeToggle_Click" Padding="8,4"
                              ToolTip="Toggle dark/light theme">
                    <TextBlock x:Name="ThemeIcon" Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </ToggleButton>
            </Grid>
        </Border>

        <!-- Bottom status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0">
                <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="1" HorizontalContentAlignment="Stretch">
                <ProgressBar Height="16" Minimum="0" Maximum="100" Value="{Binding ProgressPercent, Mode=OneWay}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main content: switches between Wizard and Classic -->
        <Grid Margin="8">
            <local:WizardView x:Name="wizardView" Visibility="{Binding IsWizardMode, Converter={StaticResource BoolToVis}}"/>
            <local:ClassicView x:Name="classicView" Visibility="{Binding IsWizardMode, Converter={StaticResource InvBoolToVis}}"/>
        </Grid>
    </DockPanel>
</Window>
