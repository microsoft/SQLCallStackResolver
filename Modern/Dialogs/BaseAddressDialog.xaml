<Window x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.BaseAddressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Enter Module Base Addresses" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8"
                   Text="Paste the output of: select name, base_address from sys.dm_os_loaded_modules where name not like '%.rll'"/>
        <TextBox Grid.Row="1" x:Name="InputAddresses" AcceptsReturn="True" AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="13" TextWrapping="NoWrap"
                 AllowDrop="True" PreviewDragOver="InputAddresses_DragOver" Drop="InputAddresses_Drop"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Load from file..." Width="100" Margin="0,0,8,0" Click="LoadFromFile_Click"/>
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
