<Window x:Class="Microsoft.SqlServer.Utils.Misc.SQLCallStackResolver.Modern.FieldSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Select Relevant XEvent Fields" Height="500" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Select the XEvent actions and fields to import:" Margin="0,0,0,8"/>
        <ListView Grid.Row="1" x:Name="FieldsListView" SelectionMode="Multiple">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsChecked}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Type" Width="70" DisplayMemberBinding="{Binding Category}"/>
                    <GridViewColumn Header="Name" Width="300" DisplayMemberBinding="{Binding Name}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Add Item" Width="80" Margin="0,0,8,0" Click="AddItem_Click"/>
            <Button Content="Delete Selected" Width="100" Margin="0,0,8,0" Click="DeleteItem_Click"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
